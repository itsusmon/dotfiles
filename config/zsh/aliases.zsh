# ============================================================================
#  Aliases
# ============================================================================

# ls with colors
alias ls='ls -G'
alias ll='ls -lah'
alias la='ls -A'

# Safety nets
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# Quick navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Grep with color
alias grep='grep --color=auto'
